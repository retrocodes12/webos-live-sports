{
  "name": "webos-live-sports",
  "private": true,
  "version": "0.1.1",
  "type": "module",
  "scripts": {
    "dev": "concurrently -k \"npm:dev:server\" \"npm:dev:client\"",
    "dev:client": "vite",
    "dev:server": "node server.mjs",
    "build": "tsc -b && vite build",
    "build:webos": "tsc -b && vite build --base=./ --minify=false --target=es2017",
    "lint": "eslint .",
    "preview": "vite preview",
    "start": "node server.mjs",
    "prepare:webos": "node scripts/prepare-webos.mjs",
    "package:webos": "npm run build:webos && npm run prepare:webos && ares-package ./dist-webos"
  },
  "dependencies": {
    "dotenv": "^17.2.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^24.12.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.57.0",
    "vite": "^8.0.1"
  }
}
